# --- Speech / LLM ---
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# --- Twilio (voice) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Server (Twilio webhooks / Media Streams) ---
# Public HTTPS URL (e.g. ngrok) without trailing slash.
SERVER_URL=https://your-subdomain.ngrok-free.app

# Inbound default agent — name in Supabase agents table (e.g. chris/claim_status)
DEFAULT_INBOUND_AGENT=chris/claim_status

# --- Optional: LiveKit local testing ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM_NAME=

# --- Optional: debug ---
ENABLE_WHISKER=false

# --- Supabase (post-call data, recordings, batch files) ---
# Project URL and service_role key (Dashboard → Settings → API).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
