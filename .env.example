# --- Speech / LLM ---
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# --- Twilio (voice) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Server (Twilio webhooks / Media Streams) ---
# Public HTTPS URL (e.g. ngrok) without trailing slash.
SERVER_URL=https://your-subdomain.ngrok-free.app

# Inbound default agent — agent name in the Aurora voice_agents table
# (e.g. chris-claim-status; Lambda-managed, see core/lambda_client.py)
DEFAULT_INBOUND_AGENT=chris-claim-status

# --- Optional: LiveKit local testing ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM_NAME=

# --- Optional: debug ---
ENABLE_WHISKER=false

# --- Data layer ---
# Post-call data, batch state, agent config, and recordings live in Aurora
# behind a Node.js Lambda. This repo talks to the Lambda; there's no direct
# Aurora URL to configure here. See core/lambda_client.py for the invoke
# path. Recordings are written to S3 by the Lambda (see the
# voice_call_requests + recordings tables for routing).
